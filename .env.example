# ============================================================
# Notificas App - Variables de Entorno
# ============================================================
# Copiar este archivo a .env y completar con valores reales.
# NUNCA commitear el archivo .env con valores reales.
# ============================================================

# === Backend API ===
# La URL base de la API (sin barra final) está en:
#   src/environments/environment.ts       → desarrollo (localhost:3000)
#   src/environments/environment.prod.ts  → producción / Firebase Hosting
# El build de producción reemplaza environment.ts por environment.prod.ts (angular.json).
# GitLab CI puede sobrescribir apiUrl en environment.prod.ts con la variable CI $API.
NOTIFICAS_API_URL=http://localhost:3000

# === AWS (solo para deploy con Terraform) ===
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=your-aws-profile
AWS_ACCOUNT_ID=000000000000

# === Terraform State ===
TF_STATE_BUCKET=your-terraform-state-bucket
TF_LOCK_TABLE=your-terraform-lock-table

# === ACM Certificates (para CloudFront HTTPS) ===
ACM_CERT_ARN_PROD=arn:aws:acm:us-east-1:000000000000:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ACM_CERT_ARN_STAGING=arn:aws:acm:us-east-1:000000000000:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === Dominios ===
DOMAIN_PROD=app.notificas.com
DOMAIN_STAGING=preprod.notificas.com

# === Firebase Hosting (solo para deploy de mantenimiento) ===
FIREBASE_PROJECT_ID=your-firebase-project

# === GitLab CI (configurar en GitLab CI/CD Settings > Variables) ===
# CI_COMMIT_REF_NAME (automatica)
# DB_PORT (referenciada en .gitlab-ci.yml)

# === MercadoPago (configurado en el backend) ===
# MP_ACCESS_TOKEN=your-mercadopago-token
# MP_PUBLIC_KEY=your-mercadopago-public-key
